UPSTREAM_REPO=https://github.com/CachyOS/linux-cachyos.git
UPSTREAM_REF=master
UPSTREAM_SUBDIR=linux-cachyos-bore

CPU_SCHED=bore
PROCESSOR_OPT=generic_v3
USE_LLVM_LTO=thin
USE_LTO_SUFFIX=yes
CC_HARDER=yes
HZ_TICKS=1000
TICKRATE=full
PREEMPT=full
HUGEPAGE=always
PER_GOV=no
TCP_BBR3=no
USE_KCFI=no

MAKEPKG_SYNCDEPS=no
PACKAGE_OUTPUT_DIR=out
PATCH_DIR=patches
